# ==============================================================================
# FairMediator Backend — Environment Variable Template
# ==============================================================================
# Copy to `backend/.env` and fill in real values. Never commit `.env`.
# All `*_SECRET` / `*_API_KEY` / `*_TOKEN` values must be kept private.
# ==============================================================================

# ------------------------------------------------------------------------------
# RUNTIME
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=4001
FRONTEND_URL=http://localhost:4010
API_URL=http://localhost:4001
SITE_URL=http://localhost:4010
CORS_ORIGIN=http://localhost:4010

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/fairmediator
MONGODB_SIZE_LIMIT=512

# ------------------------------------------------------------------------------
# AUTH / SECRETS — generate with: openssl rand -hex 32
# ------------------------------------------------------------------------------
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ROLE_SECRET=
SESSION_SECRET=
CSRF_SECRET=
INTERNAL_API_TOKEN=

# ------------------------------------------------------------------------------
# AI / HUGGING FACE
# ------------------------------------------------------------------------------
AI_MODE=huggingface
HUGGINGFACE_API_KEY=
HF_MODEL_CHAT=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_DAILY_LIMIT=333
HUGGINGFACE_MONTHLY_LIMIT=10000

# ------------------------------------------------------------------------------
# EMAIL (Resend)
# ------------------------------------------------------------------------------
EMAIL_MODE=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_DAILY_LIMIT=50
RESEND_MONTHLY_LIMIT=1500
EMAIL_REPLY_TO=
EMAIL_SUPPORT=
EMAIL_PARTNERSHIPS=

# ------------------------------------------------------------------------------
# LOGGING (Axiom)
# ------------------------------------------------------------------------------
LOGS_ENABLED=true
LOG_LEVEL=info
AXIOM_ENABLED=true
AXIOM_TOKEN=
AXIOM_DATASET=fairmediator-logs
AXIOM_ORG_ID=
AXIOM_DAILY_LIMIT=5666
AXIOM_MONTHLY_LIMIT=170000

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------------------------------------------
# FREE TIER QUOTA THRESHOLDS (percent, 0-100)
# ------------------------------------------------------------------------------
FREE_TIER_WARNING_THRESHOLD=70
FREE_TIER_ALERT_THRESHOLD=85
FREE_TIER_CRITICAL_THRESHOLD=95
FREE_TIER_STOP_THRESHOLD=100

# ------------------------------------------------------------------------------
# EXTERNAL APIs (legal data sources, FEC, OpenSecrets)
# ------------------------------------------------------------------------------
COURTLISTENER_API_KEY=
RECAP_API_KEY=
FEC_API_KEY=
OPENSECRETS_API_KEY=

# ------------------------------------------------------------------------------
# PAYMENTS (Stripe)
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# VECTOR / SEARCH BACKENDS
# ------------------------------------------------------------------------------
CHROMADB_URL=http://localhost:8000
WEAVIATE_ENABLED=false
WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_SCHEME=https
HYBRID_KEYWORD_WEIGHT=0.4
HYBRID_VECTOR_WEIGHT=0.6

# ------------------------------------------------------------------------------
# CONFLICT / PREDICTION MODELS
# ------------------------------------------------------------------------------
CONFLICT_MODEL_VERSION=v1
PREDICTOR_API_URL=

# ------------------------------------------------------------------------------
# CLOUDFLARE / WAF (production only)
# ------------------------------------------------------------------------------
CLOUDFLARE_ENABLED=false
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
AWS_REGION=us-east-1
AWS_SNS_TOPIC_ARN=
AWS_WAF_ENABLED=false
AWS_WAF_WEB_ACL_NAME=

# ------------------------------------------------------------------------------
# DEPLOYMENT (Netlify / Oracle Cloud)
# ------------------------------------------------------------------------------
NETLIFY_BLOBS_ENABLED=false
NETLIFY_SITE_ID=
NETLIFY_TOKEN=
ORACLE_BANDWIDTH_DAILY_LIMIT=10
ORACLE_BANDWIDTH_LIMIT=300
ORACLE_CPU_LIMIT=1
ORACLE_RAM_LIMIT=1
ORACLE_STORAGE_LIMIT=200

# ------------------------------------------------------------------------------
# SCRAPING QUOTAS
# ------------------------------------------------------------------------------
SCRAPING_DAILY_LIMIT=450
SCRAPING_MONTHLY_LIMIT=13500
