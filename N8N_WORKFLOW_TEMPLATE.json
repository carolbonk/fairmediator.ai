{
  "name": "FairMediator: Deploy → Scrape → Blog Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "fairmediator-deploy",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "GitHub Deploy Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_URL }}/api/monitoring/quota-status",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "check-quota",
      "name": "Check Scraping Quota",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.scraping.status }}",
              "operation": "notEqual",
              "value2": "critical"
            }
          ]
        }
      },
      "id": "quota-available",
      "name": "Quota Available?",
      "type": "n8n-nodes-base.if",
      "position": [650, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_URL }}/api/scraping/trigger-batch",
        "qs": {
          "scraper": "fec",
          "count": "10"
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "trigger-scraping",
      "name": "Trigger FEC Scraping",
      "type": "n8n-nodes-base.httpRequest",
      "position": [850, 200]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_URL }}/api/scraping/summary",
        "qs": {
          "days": "1"
        }
      },
      "id": "get-summary",
      "name": "Get Scraping Summary",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 200]
    },
    {
      "parameters": {
        "url": "={{ $env.RESEARCH_API_URL }}",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "bodyParametersJson": "={{ JSON.stringify({\n  model: $env.RESEARCH_MODEL,\n  messages: [{\n    role: 'user',\n    content: `Research the legal and ethical implications of ${$json.topDonors[0].name} donations to mediators. Focus on potential bias in ${$json.topDonors[0].industry} disputes. Provide citations.`\n  }]\n}) }}"
      },
      "id": "research-perplexity",
      "name": "Research with Perplexity",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1250, 200]
    },
    {
      "parameters": {
        "jsCode": "// Generate blog post outline\nconst summary = $input.first().json;\nconst research = $input.last().json;\n\nconst outline = {\n  title: `What ${summary.newDonations} New Mediator Donations Reveal About Bias`,\n  date: new Date().toISOString(),\n  findings: [\n    `${summary.newMediators} new mediators added to database`,\n    `$${summary.totalDonationAmount.toLocaleString()} in total donations`,\n    `Top donor: ${summary.topDonors[0].name} (${summary.topDonors[0].industry})`\n  ],\n  researchContext: research.choices[0].message.content,\n  citations: research.citations || [],\n  nextSteps: [\n    'Deep dive into top donor influence',\n    'State-by-state comparison',\n    'Interview mediators about disclosure'\n  ]\n};\n\nreturn { json: outline };"
      },
      "id": "generate-outline",
      "name": "Generate Blog Outline",
      "type": "n8n-nodes-base.code",
      "position": [1450, 200]
    },
    {
      "parameters": {
        "path": "={{ $env.BLOG_DRAFTS_PATH }}",
        "fileName": "={{ $json.date.split('T')[0] }} - {{ $json.title }}.md",
        "data": "=# {{ $json.title }}\n\n**Date:** {{ $json.date }}\n\n## Key Findings\n\n{{ $json.findings.map(f => `- ${f}`).join('\\n') }}\n\n## Research Context\n\n{{ $json.researchContext }}\n\n## Next Steps\n\n{{ $json.nextSteps.map(s => `- [ ] ${s}`).join('\\n') }}\n\n## Citations\n\n{{ $json.citations.map(c => `- ${c}`).join('\\n') }}"
      },
      "id": "save-obsidian",
      "name": "Save to Obsidian",
      "type": "n8n-nodes-base.writeFile",
      "position": [1650, 200]
    },
    {
      "parameters": {
        "url": "={{ $env.SOCIAL_API_URL }}",
        "method": "POST",
        "authentication": "oAuth2Api",
        "bodyParametersJson": "={{ JSON.stringify({\n  text: `🚀 New research: We analyzed ${$json.findings[0]} mediator donations. Top finding: ${$json.findings[2]}\\n\\nFull analysis coming soon on the FairMediator blog.`\n}) }}"
      },
      "id": "tweet",
      "name": "Tweet Finding",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1850, 200]
    },
    {
      "parameters": {
        "fromEmail": "={{ $env.ALERT_FROM_EMAIL }}",
        "toEmail": "={{ $env.ALERT_TO_EMAIL }}",
        "subject": "Scraping quota exhausted - resuming tomorrow",
        "emailType": "text",
        "message": "=Scraping quota: {{ $json.scraping.used }}/{{ $json.scraping.limit }}\\n\\nNext reset: {{ $json.scraping.nextReset }}"
      },
      "id": "quota-alert",
      "name": "Send Quota Alert",
      "type": "n8n-nodes-base.emailSend",
      "position": [850, 400]
    },
    {
      "parameters": {
        "path": "={{ $env.AUTOMATION_LOGS_PATH }}",
        "fileName": "={{ $now.format('yyyy-MM-dd') }} - Quota Alert.md",
        "data": "=# Quota Alert - {{ $now.format('yyyy-MM-dd HH:mm') }}\n\n**Status:** {{ $json.scraping.status }}\n**Used:** {{ $json.scraping.used }}/{{ $json.scraping.limit }}\n**Next Reset:** {{ $json.scraping.nextReset }}\n\n## Action Taken\n- Scraping paused\n- Alert sent\n- Will resume after quota reset"
      },
      "id": "log-obsidian",
      "name": "Log to Obsidian",
      "type": "n8n-nodes-base.writeFile",
      "position": [1050, 400]
    }
  ],
  "connections": {
    "webhook-trigger": {
      "main": [[{"node": "check-quota", "type": "main", "index": 0}]]
    },
    "check-quota": {
      "main": [[{"node": "quota-available", "type": "main", "index": 0}]]
    },
    "quota-available": {
      "main": [
        [{"node": "trigger-scraping", "type": "main", "index": 0}],
        [{"node": "quota-alert", "type": "main", "index": 0}]
      ]
    },
    "trigger-scraping": {
      "main": [[{"node": "get-summary", "type": "main", "index": 0}]]
    },
    "get-summary": {
      "main": [[{"node": "research-perplexity", "type": "main", "index": 0}]]
    },
    "research-perplexity": {
      "main": [[{"node": "generate-outline", "type": "main", "index": 0}]]
    },
    "generate-outline": {
      "main": [[{"node": "save-obsidian", "type": "main", "index": 0}]]
    },
    "save-obsidian": {
      "main": [[{"node": "tweet", "type": "main", "index": 0}]]
    },
    "quota-alert": {
      "main": [[{"node": "log-obsidian", "type": "main", "index": 0}]]
    }
  }
}
