# ==============================================================================
# FairMediator .gitignore
# ==============================================================================
# Organized by category for easy navigation and maintenance
# ==============================================================================

# ==============================================================================
# DEPENDENCIES
# ==============================================================================
node_modules/
*/node_modules/
node_modules.old/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
automation/venv/

# ==============================================================================
# ENVIRONMENT VARIABLES - NEVER COMMIT
# ==============================================================================
# Contains secrets, API keys, database credentials
.env
.env.local
.env.*.local
.env.test
.env.production
.env.development
.env.backup
.env.*backup*
*.env.backup
*/.env
**/.env
automation/.env

# Backup files (may contain secrets)
*.backup
**/*.backup

# ==============================================================================
# PERSONAL DEVELOPER CONFIGURATIONS - NEVER COMMIT
# ==============================================================================
# Personal shortcuts, aliases, and local settings (inspired by bonks pattern)
.local-aliases
.local-config
.personal/
**/.local-*
.dev-shortcuts
local.config.json

# ==============================================================================
# BUILD ARTIFACTS
# ==============================================================================
frontend/dist/
frontend/build/
backend/dist/
lighthouse-report*.html
lighthouse-report*.json

# ==============================================================================
# IDE AND EDITOR
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==============================================================================
# OPERATING SYSTEM
# ==============================================================================
.DS_Store
Thumbs.db

# ==============================================================================
# LOGS
# ==============================================================================
*.log
logs/
backend/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================================
# DATABASE FILES
# ==============================================================================
*.sqlite
*.db

# ==============================================================================
# RUNTIME STATE FILES
# ==============================================================================
# Generated at runtime by data population services; not source-of-truth
backend/data/population_status.json
backend/data/runtime/

# ==============================================================================
# SENSITIVE DATA
# ==============================================================================
# Scraped mediator data (may contain PII)
automation/scrapers/data/
scraped_data/

# Jupyter notebooks (may contain API keys in cells)
*.ipynb
.ipynb_checkpoints/
notebooks/*.ipynb
**/.ipynb_checkpoints/

# ==============================================================================
# TESTING
# ==============================================================================
coverage/
.nyc_output/

# ==============================================================================
# TEMPORARY FILES
# ==============================================================================
tmp/
temp/

# ==============================================================================
# DEPLOYMENT AND INFRASTRUCTURE - HIDE ALL
# ==============================================================================
# Docker backups (contain sensitive database dumps)
backups/

# Infrastructure Configuration (Traefik, Prometheus, Grafana)
config/
**/config/traefik/
**/config/prometheus/
**/config/grafana/

# CI/CD Workflows (reveals deployment strategy)
.github/workflows/*.yml
!.github/workflows/security-scan.yml

# Deployment platform configs
.vercel/
.netlify/
netlify.toml
**/netlify.toml

# Secret scanning baseline (reveals what we're hiding)
.secrets.baseline
**/.secrets.baseline

# ==============================================================================
# DOCUMENTATION - INTERNAL ONLY
# ==============================================================================
# Exclude all markdown files (contains internal strategy, business plans, deployment guides)
*.md
**/*.md
*.markdown
**/*.markdown
*.mdx
**/*.mdx

# Allow essential public documentation only (ONLY 3 DOCS)
!README.md
!CONTRIBUTING.md
!SECURITY.md

# ==============================================================================
# CREDENTIALS, KEYS, CERTIFICATES - NEVER COMMIT
# ==============================================================================
# Private keys / SSH / PGP
*.pem
*.key
*.crt
*.cer
*.cert
*.der
*.pfx
*.p12
*.jks
*.keystore
*.asc
*.gpg
*.pgp
id_rsa
id_rsa.*
id_dsa
id_dsa.*
id_ecdsa
id_ecdsa.*
id_ed25519
id_ed25519.*
*_rsa
*_dsa
*_ecdsa
*_ed25519

# Cloud / service-account credential files
credentials
credentials.*
credentials.json
*credentials*.json
service-account*.json
*service-account*.json
gcp-key*.json
google-credentials*.json
firebase-adminsdk*.json
aws-credentials
.aws/
.gcloud/
.azure/

# Tooling credential files
.npmrc
.yarnrc
.pypirc
.netrc
.pgpass
.htpasswd
auth.json
secrets.json
secrets.yaml
secrets.yml
**/secrets.json
**/secrets.yaml
**/secrets.yml

# Token / API key drop files
*.token
*token*.txt
api-key*
api_key*

# ==============================================================================
# DEPLOYMENT SCRIPTS - INTERNAL ONLY
# ==============================================================================
# Hide all shell scripts (deployment, backup, verification scripts)
*.sh
**/*.sh

# Hide all Docker Compose files except base docker-compose.yml
docker-compose.*.yml
!docker-compose.yml

# Hide environment-specific Docker files
.env.docker

# ==============================================================================
# INTERNAL DEVELOPMENT WORKFLOWS
# ==============================================================================
# Claude Code configuration (skills, commands, internal context)
.claude/
**/.claude/

# Internal automation (SRE agents, N8N workflows)
backend/.ai/
**/.ai/
N8N_WORKFLOW_TEMPLATE.json
**/N8N_*.json

# Internal documentation directory (operational details, infrastructure specs)
docs/
**/docs/
.env.production.template
