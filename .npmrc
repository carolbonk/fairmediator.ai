# FairMediator npm configuration
# Security settings to prevent vulnerable dependencies

# Save exact versions (no ^ or ~)
save-exact=true

# Always maintain package-lock.json
package-lock=true

# Run security audits on install
audit=true

# Engine strict mode - respect engines field in package.json
engine-strict=false

# Legacy peer deps handling (set to true if you encounter peer dependency conflicts)
legacy-peer-deps=false

# SECURITY: Blocked axios versions due to known vulnerabilities
# - axios@1.14.1: [vulnerability description]
# - axios@0.30.4: [vulnerability description]
# These are blocked via preinstall script: scripts/check-axios-version.js
# Approved version: axios@1.13.5
