# ==============================================================================
# FairMediator Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# ==============================================================================

# ==============================================================================
# APPLICATION ENVIRONMENT
# ==============================================================================
NODE_ENV=development  # Options: development, production, test

# ==============================================================================
# PORT ALLOCATION (FairMediator Range: 4000-4099)
# ==============================================================================
# All services use standardized port range for organization and conflict prevention
# See PORT_ALLOCATION.md for complete documentation

# Core Application Ports (4000-4009)
FRONTEND_PORT=4000          # Production frontend (React/Nginx)
BACKEND_PORT=4001           # Production backend API
PORT=5001                   # Internal backend port (container-internal)

# Development Ports (4010-4019)
DEV_FRONTEND_PORT=4010      # Development frontend with HMR
DEV_BACKEND_PORT=4011       # Development backend with auto-reload
DEV_DEBUG_PORT=4012         # Node.js debugger port
DEV_MAILHOG_UI_PORT=4013    # Mailhog web UI for email testing
DEV_MAILHOG_SMTP_PORT=4014  # Mailhog SMTP server

# Monitoring Ports (4020-4029)
TRAEFIK_DASHBOARD_PORT=4020 # Traefik reverse proxy dashboard
PROMETHEUS_PORT=4021        # Prometheus metrics collection
GRAFANA_PORT=4022           # Grafana monitoring dashboards
CADVISOR_PORT=4023          # Container resource metrics
NODE_EXPORTER_PORT=4024     # System-level metrics

# Database Ports (4030-4039)
MONGODB_PORT=4030           # MongoDB database
MONGO_EXPRESS_PORT=4031     # MongoDB web admin (dev only)

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# MongoDB Connection
MONGODB_URI=mongodb://admin:changeme@mongodb:27017/fairmediator?authSource=admin
MONGODB_USER=admin
MONGODB_PASSWORD=changeme  # CHANGE THIS IN PRODUCTION!

# ==============================================================================
# SECURITY SECRETS (REQUIRED - Generate Strong Values)
# ==============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=your_jwt_secret_here_generate_with_crypto_randomBytes
SESSION_SECRET=your_session_secret_here_generate_with_crypto_randomBytes
CSRF_SECRET=your_csrf_secret_here_generate_with_crypto_randomBytes
ENCRYPTION_KEY=your_encryption_key_here_32_bytes_hex

# ==============================================================================
# CORS & API CONFIGURATION
# ==============================================================================

# Frontend URL for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:4010,http://localhost:4000

# API Base URL (for frontend to call backend)
VITE_API_URL=http://localhost:4011/api  # Dev
# VITE_API_URL=http://localhost:4001/api  # Prod

# WebSocket URL (if using WebSockets)
VITE_WS_URL=ws://localhost:4011

# ==============================================================================
# EXTERNAL API KEYS & RATE LIMITS
# ==============================================================================

# Hugging Face (AI/ML Models)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_DAILY_LIMIT=333  # Free tier: 10k/month ÷ 30 days

# Resend (Email Service)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_DAILY_LIMIT=50  # Conservative limit (free tier: 100/day)

# FEC (Federal Election Commission - Optional)
FEC_API_KEY=DEMO_KEY  # Get free key at api.data.gov

# OpenRouter (Alternative AI Provider - Optional)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_DAILY_LIMIT=333

# Scraping Rate Limits
SCRAPING_DAILY_LIMIT=450  # 15k/month ÷ 30 days

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================

# Axiom (Cloud Logging)
AXIOM_DATASET=your_dataset_name
AXIOM_TOKEN=your_axiom_token_here
AXIOM_ORG_ID=your_axiom_org_id_here
AXIOM_ENABLED=true  # Set to false to disable cloud logging

# Sentry (Error Tracking - Optional)
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development

# ==============================================================================
# ORACLE CLOUD ALWAYS FREE TIER LIMITS
# ==============================================================================
# Resource monitoring for deployment safety

ORACLE_CPU_LIMIT=4          # 4 OCPU cores
ORACLE_RAM_LIMIT=24576      # 24 GB in MB
ORACLE_STORAGE_LIMIT=204800 # 200 GB in MB
ORACLE_BANDWIDTH_LIMIT=4096 # 4TB in GB (40% of 10TB per month)
ORACLE_BANDWIDTH_DAILY_LIMIT=136 # 136GB per day (~4TB/30 days)

# ==============================================================================
# PAYMENT & MONETIZATION (Optional)
# ==============================================================================

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# ==============================================================================
# GRAFANA CONFIGURATION (Management Stack)
# ==============================================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme  # CHANGE THIS!
GRAFANA_SECRET_KEY=your_grafana_secret_key_here

# ==============================================================================
# DOCKER COMPOSE CONFIGURATION
# ==============================================================================

# Project name for Docker resource isolation
COMPOSE_PROJECT_NAME=fairmediator

# ==============================================================================
# FEATURE FLAGS & MODES
# ==============================================================================

# AI Mode (set to 'off' to disable AI features and save quota)
AI_MODE=on

# Email Mode (set to 'off' to disable email sending)
EMAIL_MODE=on

# ==============================================================================
# DEVELOPMENT TOOLS
# ==============================================================================

# Mailhog (Email Testing in Dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ==============================================================================
# IMPORTANT SECURITY NOTES
# ==============================================================================
# 1. NEVER commit .env to version control (already in .gitignore)
# 2. Use different secrets for dev/staging/production
# 3. Rotate secrets regularly (see scripts/rotateSecrets.js)
# 4. Use environment-specific .env files:
#    - .env.development
#    - .env.staging
#    - .env.production
# 5. Store production secrets in secure vault (not in files)
# ==============================================================================
