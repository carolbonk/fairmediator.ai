# ==============================================================================
# FairMediator Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# ==============================================================================

# ==============================================================================
# APPLICATION ENVIRONMENT
# ==============================================================================
NODE_ENV=development  # Options: development, production, test

# ==============================================================================
# PORT ALLOCATION (FairMediator Range: 4000-4099)
# ==============================================================================
# All services use standardized port range for organization and conflict prevention
# See PORT_ALLOCATION.md for complete documentation

# Core Application Ports (4000-4009)
FRONTEND_PORT=4010          # Production frontend (React/Nginx)
BACKEND_PORT=4001           # Production backend API
PORT=4001                   # Internal backend port (container-internal)

# Development Ports (4010-4019)
DEV_FRONTEND_PORT=4010      # Development frontend with HMR
DEV_BACKEND_PORT=4011       # Development backend with auto-reload
DEV_DEBUG_PORT=4012         # Node.js debugger port
DEV_MAILHOG_UI_PORT=4013    # Mailhog web UI for email testing
DEV_MAILHOG_SMTP_PORT=4014  # Mailhog SMTP server

# Monitoring Ports (4020-4029)
TRAEFIK_DASHBOARD_PORT=4020 # Traefik reverse proxy dashboard
PROMETHEUS_PORT=4021        # Prometheus metrics collection
GRAFANA_PORT=4022           # Grafana monitoring dashboards
CADVISOR_PORT=4023          # Container resource metrics
NODE_EXPORTER_PORT=4024     # System-level metrics

# Database Ports (4030-4039)
MONGODB_PORT=4030           # MongoDB database
MONGO_EXPRESS_PORT=4031     # MongoDB web admin (dev only)

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# MongoDB Connection
MONGODB_URI=mongodb://admin:changeme@mongodb:27017/fairmediator?authSource=admin  # pragma: allowlist secret
MONGODB_USER=admin
MONGODB_PASSWORD=changeme  # pragma: allowlist secret - CHANGE THIS IN PRODUCTION!

# ==============================================================================
# SECURITY SECRETS (REQUIRED - Generate Strong Values)
# ==============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# JWT Authentication Secrets
JWT_SECRET=your_jwt_secret_here_generate_with_crypto_randomBytes
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_generate_with_crypto_randomBytes
JWT_ROLE_SECRET=your_jwt_role_secret_here_generate_with_crypto_randomBytes

# Session & Security
SESSION_SECRET=your_session_secret_here_generate_with_crypto_randomBytes
CSRF_SECRET=your_csrf_secret_here_generate_with_crypto_randomBytes
ENCRYPTION_KEY=your_encryption_key_here_32_bytes_hex

# ==============================================================================
# CORS & API CONFIGURATION
# ==============================================================================

# Frontend URL for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:4010,http://localhost:4000
FRONTEND_URL=http://localhost:4010  # Used in email templates for links

# API Base URL (for frontend to call backend)
VITE_API_URL=http://localhost:4011/api  # Dev
# VITE_API_URL=http://localhost:4001/api  # Prod

# WebSocket URL (if using WebSockets)
VITE_WS_URL=ws://localhost:4011

# ==============================================================================
# EXTERNAL API KEYS & RATE LIMITS
# ==============================================================================

# AI/ML API Key
AI_API_KEY=your_ai_api_key_here
AI_DAILY_LIMIT=333

# Email Service (Resend.com - 3000 emails/month free)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@fairmediator.ai
EMAIL_REPLY_TO=contact@fairmediator.ai
EMAIL_SUPPORT=support@fairmediator.ai
EMAIL_PARTNERSHIPS=partnerships@fairmediator.ai
EMAIL_DAILY_LIMIT=50

# Government Data API (Optional)
GOV_DATA_API_KEY=DEMO_KEY

# Alternative AI Provider (Optional)
ALT_AI_API_KEY=your_alt_ai_api_key_here
ALT_AI_DAILY_LIMIT=333

# Data Collection Rate Limits
SCRAPING_DAILY_LIMIT=450

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================

# Cloud Logging Service
LOGGING_DATASET=your_dataset_name
LOGGING_TOKEN=your_logging_token_here
LOGGING_ORG_ID=your_logging_org_id_here
LOGGING_ENABLED=true  # Set to false to disable cloud logging

# Error Tracking Service (Optional)
ERROR_TRACKING_DSN=your_error_tracking_dsn_here
ERROR_TRACKING_ENVIRONMENT=development

# ==============================================================================
# CLOUD INFRASTRUCTURE LIMITS
# ==============================================================================
# Resource monitoring for deployment safety

CLOUD_CPU_LIMIT=4
CLOUD_RAM_LIMIT=24576       # In MB
CLOUD_STORAGE_LIMIT=204800  # In MB
CLOUD_BANDWIDTH_LIMIT=4096  # In GB per month
CLOUD_BANDWIDTH_DAILY_LIMIT=136

# ==============================================================================
# PAYMENT & MONETIZATION (Optional)
# ==============================================================================

# Payment Processing Service
PAYMENT_SECRET_KEY=your_payment_secret_key_here
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret_here
PAYMENT_PUBLISHABLE_KEY=your_payment_publishable_key_here

# ==============================================================================
# MONITORING DASHBOARD CONFIGURATION
# ==============================================================================

DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=changeme  # CHANGE THIS!
DASHBOARD_SECRET_KEY=your_dashboard_secret_key_here

# ==============================================================================
# DOCKER COMPOSE CONFIGURATION
# ==============================================================================

# Project name for Docker resource isolation
COMPOSE_PROJECT_NAME=fairmediator

# ==============================================================================
# FEATURE FLAGS & MODES
# ==============================================================================

# AI Mode (set to 'off' to disable AI features and save quota)
AI_MODE=on

# Email Mode (set to 'off' to disable email sending)
EMAIL_MODE=on

# ==============================================================================
# DEVELOPMENT TOOLS
# ==============================================================================

# Mailhog (Email Testing in Dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ==============================================================================
# IMPORTANT SECURITY NOTES
# ==============================================================================
# 1. NEVER commit .env to version control (already in .gitignore)
# 2. Use different secrets for dev/staging/production
# 3. Rotate secrets regularly (see scripts/rotateSecrets.js)
# 4. Use environment-specific .env files:
#    - .env.development
#    - .env.staging
#    - .env.production
# 5. Store production secrets in secure vault (not in files)
# ==============================================================================
